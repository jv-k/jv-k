{
  "name": "jv-k",
  "version": "2.0.2",
  "description": "GitHub profile README generator with dynamic skillset icons",
  "main": "./src/main.ts",
  "bin": {
    "jv-k": "./src/cli.ts"
  },
  "repository": "ssh://git@github.com/jv-k/jv-k",
  "author": "John Valai <git@jvk.to>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "start": "bun ./src/cli.ts",
    "build": "bun ./src/main.ts",
    "prebuild": "bun run fetch-icons",
    "fetch-icons": "bun ./src/fetch-icons.ts",
    "fetch-icons:fresh": "rm -rf assets/icons && bun ./src/fetch-icons.ts",
    "fetch-icons:help": "bun ./src/fetch-icons.ts --help",
    "watch": "nodemon --ext ts --exec bun run build",
    "validate": "bun run typecheck && bun run lint",
    "test": "bun test --ci",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:yaml": "bun ./tests/test.yaml.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:yaml": "yamllint src/data/mystack.yml",
    "typecheck": "tsc --noEmit",
    "ci": "bun run typecheck && bun run lint && bun run test",
    "bump": "ver-bump -b"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "js-yaml": "^4.1.0",
    "node-yaml-config": "^1.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "pug": "^3.0.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "bun": "^1.1.18",
    "@types/bun": "^1.3.5",
    "@types/js-yaml": "4.0.9",
    "@types/node": "25.0.3",
    "@types/pug": "2.0.10",
    "eslint": "^9.39.2",
    "nodemon": "^3.1.4",
    "prettier": "^3.7.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.52.0"
  }
}
