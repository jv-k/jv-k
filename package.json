{
  "name": "jv-k",
  "version": "2.0.2",
  "description": "GitHub profile README generator with dynamic skillset icons",
  "main": "./src/main.ts",
  "bin": {
    "jv-k": "./src/cli.ts"
  },
  "repository": "ssh://git@github.com/jv-k/jv-k",
  "author": "John Valai <git@jvk.to>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "lint": "eslint src/**/*.js",
    "start": "bun ./src/cli.ts",
    "build": "bun ./src/main.ts",
    "watch": "nodemon --ext ts --exec bun run build",
    "test": "bun test --ci",
    "test:yaml": "bun ./tests/test.yaml.ts",
    "typecheck": "tsc --noEmit",
    "bump": "ver-bump -b"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "js-yaml": "^4.1.0",
    "node-yaml-config": "^1.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "pug": "^3.0.2"
  },
  "devDependencies": {
    "eslint": "^8.0.1",
    "eslint-config-google": "^0.14.0",
    "eslint-config-standard": "^17.0.0",
    "eslint-plugin-import": "^2.25.2",
    "eslint-plugin-n": "^15.0.0",
    "eslint-plugin-promise": "^6.0.0",
    "@types/bun": "^1.3.5",
    "@types/js-yaml": "4.0.9",
    "@types/node": "25.0.3",
    "@types/pug": "2.0.10",
    "nodemon": "^3.1.4",
    "typescript": "5.9.3",
  }
}
